{
  "name": "letitrip.in",
  "version": "2.7.43",
  "private": true,
  "scripts": {
    "predev": "node scripts/stop-dev.mjs",
    "dev": "concurrently --kill-others --restart-tries 0 --names \"appkit,css,next\" \"npm run watch:appkit\" \"npm run watch:css\" \"npm run dev:only\"",
    "stop": "node scripts/stop-dev.mjs",
    "dev:only": "cross-env NODE_OPTIONS=--max-old-space-size=3072 VERCEL_HOBBY_TIER=1 node scripts/dev-next.mjs",
    "prewarm": "node scripts/prewarm.mjs",
    "watch:appkit": "npm --prefix ./appkit run watch",
    "watch:css": "tailwindcss -i ./src/app/globals.css -o ./src/styles/globals.compiled.css --watch",
    "build:css": "tailwindcss -i ./src/app/globals.css -o ./src/styles/globals.compiled.css --minify",
    "prebuild": "npm run build:css",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:smoke": "node scripts/qa/smoke-prod.mjs",
    "test:smoke:only": "node scripts/qa/smoke-prod.mjs --only",
    "test:pw": "node scripts/qa/smoke-pw.mjs",
    "test:pw:only": "node scripts/qa/smoke-pw.mjs --only",
    "test:audit": "node scripts/qa/audit-browser.mjs",
    "test:audit:existing": "cross-env AUDIT_USE_EXISTING=1 node scripts/qa/audit-browser.mjs",
    "audit:ssr-in-appkit": "node scripts/audit-ssr-in-appkit.mjs",
    "audit:og-coverage": "node appkit/scripts/verify-og-coverage.mjs",
    "audit:hex-tokens": "node scripts/audit-hex-tokens.mjs",
    "audit:hex-tokens:fix": "node scripts/audit-hex-tokens.mjs --fix",
    "audit:config-factories": "node scripts/audit-config-factories.mjs",
    "pre-commit": "npm run check",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "check:types:appkit": "npm --prefix ./appkit run check:types",
    "check:types:app": "tsc --noEmit",
    "check:types": "npm run check:types:appkit && npm run check:types:app",
    "check:audits:appkit": "npm --prefix ./appkit run check:audits",
    "audit:html-wrappers": "node scripts/audit-html-wrappers.mjs",
    "audit:code-quality": "node scripts/audit-code-quality.mjs",
    "audit:suspense-boundaries": "node scripts/audit-suspense-boundaries.mjs",
    "audit:auth-gates": "node scripts/audit-auth-gates.mjs",
    "audit:inline-actions": "node scripts/audit-inline-actions.mjs",
    "audit:product-form-shell": "node scripts/audit-product-form-shell.mjs",
    "audit:dashboard-padding": "node scripts/audit-dashboard-padding.mjs",
    "audit:user-pages-overhaul": "node scripts/audit-user-pages-overhaul.mjs",
    "audit:root-cause": "node scripts/audit-root-cause.mjs",
    "check:audits": "npm run check:audits:appkit && npm run audit:ssr-in-appkit && npm run audit:og-coverage && npm run audit:hex-tokens && npm run audit:config-factories && npm run audit:html-wrappers && npm run audit:code-quality && npm run audit:bom && npm run audit:suspense-boundaries && npm run audit:auth-gates && npm run audit:inline-actions && npm run audit:product-form-shell && npm run audit:dashboard-padding && npm run audit:user-pages-overhaul && npm run audit:root-cause && npm run audit:gitignore",
    "check:lint": "npm run lint",
    "check": "npm run check:types && npm run check:audits && npm run check:lint",
    "check:fix": "npm run lint:fix && npm run check",
    "index:generate": "node ./appkit/scripts/get-index.js",
    "firebase:generate": "node ./appkit/scripts/firebase-merge.mjs",
    "firebase:deploy": "node ./appkit/scripts/firebase-merge.mjs --deploy",
    "firebase:deploy:rules": "node ./appkit/scripts/firebase-merge.mjs --deploy --only firestore:rules,storage,database",
    "firebase:deploy:indexes": "node ./appkit/scripts/firebase-merge.mjs --deploy --only firestore:indexes",
    "firebase:reset": "node ./appkit/scripts/firebase-reset.mjs",
    "firebase:reset:all": "node ./appkit/scripts/firebase-reset.mjs --yes",
    "audit:bom": "node scripts/audit-bom.mjs",
    "audit:gitignore": "node scripts/audit-gitignore.mjs"
  },
  "dependencies": {
    "@auth/firebase-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@mohasinac/appkit": "file:./appkit",
    "@mohasinac/sievejs": "^1.0.0",
    "@tanstack/react-query": "^5.90.21",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.13.5",
    "file-type": "^21.3.1",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.8.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "serwist": "^9.5.7",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "playwright": "^1.53.1",
    "postcss": "8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "overrides": {
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
