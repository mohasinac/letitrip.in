{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:appkit:watch": "pnpm --dir ../appkit watch:all",
    "dev:appkit:sync": "pnpm --dir ../appkit build",
    "dev:turbo": "next dev --turbopack",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:strict": "eslint src --max-warnings 0",
    "lint:wrappers": "eslint \"src/**/*.tsx\" \"packages/*/src/**/*.tsx\" --no-error-on-unmatched-pattern --quiet",
    "type-check": "tsc --noEmit",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "seed:faqs": "tsx scripts/seed-faqs.ts",
    "check:violations": "node scripts/check-violations.js",
    "fix:violations": "node scripts/fix-violations.js",
    "fix:violations:apply": "node scripts/fix-violations.js --apply",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@auth/firebase-adapter": "^2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@mohasinac/appkit": "^2.0.8",
    "@mohasinac/sievejs": "^1.0.0",
    "@serwist/next": "^9.5.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "algoliasearch": "^5.49.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "file-type": "^21.3.1",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.1",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "serwist": "^9.5.6",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@next/bundle-analyzer": "^16.1.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "buffer": "^6.0.3",
    "cross-env": "^10.1.0",
    "crypto-browserify": "^3.12.1",
    "eslint": "^10.0.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "8.4.49",
    "prettier": "^3.8.1",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
