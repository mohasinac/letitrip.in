{
    "name":  "letitrip.in",
    "version":  "1.0.0",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev",
                    "watch:appkit":  "npm --prefix ./appkit run watch",
                    "build":  "next build",
                    "start":  "next start",
                    "test":  "jest",
                    "test:smoke":  "node scripts/qa/smoke-pages-api.mjs",
                    "test:smoke:existing":  "cross-env SMOKE_USE_EXISTING_SERVER=1 node scripts/qa/smoke-pages-api.mjs",
                    "test:smoke:all":  "node scripts/qa/smoke-all-pages.mjs",
                    "test:smoke:all:existing":  "cross-env SMOKE_USE_EXISTING_SERVER=1 node scripts/qa/smoke-all-pages.mjs",
                                        "test:smoke:browser":  "cross-env SMOKE_SEED_FIRST=0 node scripts/qa/smoke-browser.mjs",
                                        "test:smoke:browser:watch":  "cross-env SMOKE_SEED_FIRST=0 SMOKE_HEADLESS=0 SMOKE_SLOW_MO=300 node scripts/qa/smoke-browser.mjs",
                    "pre-commit":  "npm run lint",
                    "lint":  "eslint src",
                    "lint:fix":  "eslint src --fix",
                    "index:generate":  "node ./appkit/scripts/get-index.js",
                    "firebase:generate":  "node ./appkit/scripts/firebase-merge.mjs",
                    "firebase:deploy":  "node ./appkit/scripts/firebase-merge.mjs --deploy",
                    "firebase:deploy:rules":  "node ./appkit/scripts/firebase-merge.mjs --deploy --only firestore:rules,storage,database",
                    "firebase:deploy:indexes":  "node ./appkit/scripts/firebase-merge.mjs --deploy --only firestore:indexes",
                    "firebase:reset":  "node ./appkit/scripts/firebase-reset.mjs",
                    "firebase:reset:all":  "node ./appkit/scripts/firebase-reset.mjs --yes"
                },
    "dependencies":  {
                         "@auth/firebase-adapter":  "^2.11.1",
                         "@google/generative-ai":  "^0.24.1",
                         "@hookform/resolvers":  "^5.2.2",
                         "@mohasinac/sievejs":  "^1.0.0",
                         "@tanstack/react-query":  "^5.90.21",
                         "@upstash/ratelimit":  "^2.0.8",
                         "@upstash/redis":  "^1.37.0",
                         "axios":  "^1.13.5",
                         "file-type":  "^21.3.1",
                         "firebase":  "^12.8.0",
                         "firebase-admin":  "^13.8.0",
                         "lucide-react":  "^0.575.0",
                         "next":  "^16.1.6",
                         "next-intl":  "^4.8.3",
                         "razorpay":  "^2.9.6",
                         "react":  "^19.2.0",
                         "react-dom":  "^19.2.0",
                         "react-hook-form":  "^7.71.2",
                         "recharts":  "^3.7.0",
                         "resend":  "^6.9.1",
                         "server-only":  "^0.0.1",
                         "serwist":  "^9.5.7",
                         "sharp":  "^0.33.5",
                         "tailwind-merge":  "^3.5.0",
                         "zod":  "^4.3.6",
                         "@mohasinac/appkit":  "file:./appkit"
                     },
    "devDependencies":  {
                            "@testing-library/dom":  "^10.4.1",
                            "@testing-library/jest-dom":  "^6.9.1",
                            "@testing-library/react":  "^16.3.2",
                            "@testing-library/user-event":  "^14.6.1",
                            "@types/jest":  "^30.0.0",
                            "@types/node":  "^20",
                            "@types/react":  "^19",
                            "@types/react-dom":  "^19",
                            "autoprefixer":  "^10",
                            "cross-env":  "^10.1.0",
                            "eslint":  "^10.0.1",
                            "eslint-config-next":  "^16.1.6",
                            "eslint-plugin-react":  "^7.37.5",
                            "jest":  "^30.2.0",
                            "jest-environment-jsdom":  "^30.2.0",
                            "playwright":  "^1.53.1",
                            "postcss":  "8.4.49",
                            "prettier":  "^3.8.1",
                            "tailwindcss":  "^3.4.0",
                            "ts-node":  "^10.9.2",
                            "tsup":  "^8.5.1",
                            "typescript":  "^5.9.3",
                            "typescript-eslint":  "^8.58.0"
                        }
}
