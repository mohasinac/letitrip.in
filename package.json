{
  "name": "letitrip.in",
  "version": "2.8.1",
  "private": true,
  "scripts": {
    "predev": "node scripts/stop-dev.mjs",
    "dev": "node scripts/dev-light.mjs",
    "dev:hot": "concurrently --kill-others --restart-tries 0 --names \"appkit,css,next\" \"npm run watch:appkit\" \"npm run watch:css\" \"npm run dev:only\"",
    "stop": "node scripts/stop-dev.mjs",
    "dev:only": "cross-env NODE_OPTIONS=--max-old-space-size=3072 VERCEL_HOBBY_TIER=1 node scripts/dev-next.mjs",
    "prewarm": "node scripts/prewarm.mjs",
    "watch:appkit": "npm --prefix ./appkit run watch",
    "watch:css": "tailwindcss -i ./src/app/globals.css -o ./src/styles/globals.compiled.css --watch",
    "build:css": "tailwindcss -i ./src/app/globals.css -o ./src/styles/globals.compiled.css --minify",
    "prebuild": "npm run build:css",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "analyze:logs": "node scripts/analyze-logs.mjs",
    "audit": "node scripts/run-audits.mjs",
    "audit:all": "node scripts/run-audits.mjs --all",
    "audit:fix": "node scripts/run-audits.mjs --all --fix",
    "audit:list": "node scripts/run-audits.mjs --list",
    "lint": "eslint src appkit/src",
    "lint:fix": "eslint src appkit/src --fix",
    "check:types:appkit": "npm --prefix ./appkit run check:types",
    "check:types:app": "tsc --noEmit",
    "check:types": "npm run check:types:appkit && npm run check:types:app",
    "check:audits": "npm run audit:all",
    "check:lint": "npm run lint",
    "check": "npm run check:types && npm run check:audits && npm run check:lint",
    "check:fix": "npm run lint:fix && npm run check",
    "pre-commit": "npm run check",
    "index:generate": "node ./appkit/scripts/get-index.js",
    "firebase": "node scripts/firebase.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mohasinac/appkit": "file:./appkit",
    "@mohasinac/sievejs": "^1.0.0",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "file-type": "^21.3.1",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.6",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "server-only": "^0.0.1",
    "serwist": "^9.5.7",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "postcss": "8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
