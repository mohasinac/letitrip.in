{
  "rules": {
    // ============================================================
    // Backend-Only Write Architecture
    // ============================================================
    // ALL writes come exclusively through Next.js API routes
    // using the Firebase Admin SDK (which bypasses these rules).
    //
    // Clients may ONLY subscribe (read) to paths they are
    // explicitly authorised to read via a server-issued custom
    // token.  The custom token encodes:
    //   { uid, sessionId, role, chatIds: { [chatId]: true } }
    //
    // /api/realtime/token  —  issues the custom token
    //   - Verifies active session cookie before issuing
    //   - Token lifetime ≤ 1 hour (matches session TTL)
    //   - Client calls this endpoint before the token expires
    //
    // Custom token auth flow (client-side):
    //   import { realtimeApp } from '@/lib/firebase/realtime'
    //   await signInWithCustomToken(getAuth(realtimeApp), tok.customToken)
    //   onValue(ref(getDatabase(realtimeApp), `chat/${id}/messages`), ...)
    // ============================================================
    ".read": false,
    ".write": false,

    "chat": {
      "$chatId": {
        // Client may read only if the custom token grants access to this chatId
        ".read": "auth != null && auth.token.chatIds != null && auth.token.chatIds[$chatId] == true",
        // ALL writes are Admin-only (backend API routes)
        ".write": false,
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['userId', 'message', 'timestamp'])",
            "userId": { ".validate": "newData.isString()" },
            "message": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
            },
            "timestamp": {
              ".validate": "newData.isNumber() || newData.val() == '.sv'"
            }
          }
        },
        "metadata": {
          // metadata readable alongside messages; server-written only
          ".read": "auth != null && auth.token.chatIds != null && auth.token.chatIds[$chatId] == true"
        }
      }
    },

    "notifications": {
      "$uid": {
        // User may read only their own notifications (uid in custom token must match)
        ".read": "auth != null && auth.uid == $uid",
        // ALL writes are Admin-only (backend pushes notifications)
        ".write": false,
        "$notificationId": {
          ".validate": "newData.hasChildren(['title', 'message', 'type', 'timestamp', 'read'])",
          "title": { ".validate": "newData.isString()" },
          "message": { ".validate": "newData.isString()" },
          "type": {
            ".validate": "newData.isString() && (newData.val() == 'info' || newData.val() == 'success' || newData.val() == 'warning' || newData.val() == 'error')"
          },
          "timestamp": {
            ".validate": "newData.isNumber() || newData.val() == '.sv'"
          },
          "read": { ".validate": "newData.isBoolean()" }
        }
      }
    },

    "live_updates": {
      "$updateType": {
        // Public broadcast channel — anyone may subscribe, only backend writes
        ".read": true,
        ".write": false,
        ".validate": "newData.hasChildren(['timestamp'])",
        "timestamp": {
          ".validate": "newData.isNumber() || newData.val() == '.sv'"
        }
      }
    },

    "presence": {
      "$uid": {
        // Online-presence node — client reads own node only after auth,
        // server writes via Admin SDK when session is established/expired
        ".read": "auth != null && auth.uid == $uid",
        ".write": false,
        ".validate": "newData.hasChildren(['online', 'lastSeen'])",
        "online": { ".validate": "newData.isBoolean()" },
        "lastSeen": {
          ".validate": "newData.isNumber() || newData.val() == '.sv'"
        }
      }
    },

    "auction-bids": {
      "$productId": {
        // Any authenticated user may subscribe to live bid data for an auction.
        // Actual path used by useRealtimeBids: /auction-bids/${productId}
        // All writes are Admin-only via the backend bid placement API route.
        ".read": "auth != null",
        ".write": false,
        ".validate": "newData.hasChildren(['currentBid', 'bidCount'])",
        "currentBid": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "bidCount": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "updatedAt": {
          ".validate": "newData.isNumber() || newData.val() == '.sv'"
        },
        "lastBid": {
          "amount": { ".validate": "newData.isNumber() && newData.val() > 0" },
          "bidderName": { ".validate": "newData.isString()" },
          "timestamp": {
            ".validate": "newData.isNumber() || newData.val() == '.sv'"
          }
        }
      }
    },

    "order_tracking": {
      "$orderId": {
        // Only the order owner may subscribe to live order tracking updates.
        // The custom token must contain an orderId claim matching this $orderId.
        // Token is issued by POST /api/realtime/token?orderId=<id> after verifying ownership.
        // All writes are Admin-only via backend order management routes.
        ".read": "auth != null && auth.token.orderId == $orderId",
        ".write": false,
        "$event": {
          ".validate": "newData.hasChildren(['status', 'timestamp'])",
          "status": { ".validate": "newData.isString()" },
          "timestamp": {
            ".validate": "newData.isNumber() || newData.val() == '.sv'"
          },
          "message": { ".validate": "!newData.exists() || newData.isString()" }
        }
      }
    }
  }
}
