{
  "name": "@mohasinac/css-tailwind",
  "version": "0.1.0",
  "description": "Tailwind CSS adapter implementing IStyleAdapter from @mohasinac/contracts — twMerge + CSS var tokens",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "eslint src"
  },
  "dependencies": {
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "eslint": "^9.37.0"
  },
  "peerDependencies": {
    "@mohasinac/contracts": "workspace:*"
  }
}
