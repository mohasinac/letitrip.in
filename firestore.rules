rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Backend-Only Firestore Architecture
    // ============================================================
    // NO client-side Firestore access is permitted, ever.
    //
    // All reads and writes must go through Next.js API routes
    // (src/app/api/**) using the Firebase Admin SDK, which
